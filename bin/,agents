#!/usr/bin/env bash
set -uo pipefail

emit_rows() {
  local results=()
  while IFS=$'\t' read -r tty target session; do
    if ps -t "$tty" -o args= 2>/dev/null | grep -qE "[c]laude|[a]gent"; then
      state=$(tmux show-option -p -t "$target" -qv @agent_state)
      timestamp=$(tmux show-option -p -t "$target" -qv @agent_state_at)

      case "$state" in
        waiting) state_fmt=$'\033[33m● waiting\033[0m' ;;
        idle)    state_fmt=$'\033[32m● idle\033[0m' ;;
        working) state_fmt=$'\033[31m● working\033[0m' ;;
        *)       state_fmt=$'\033[90m● unknown\033[0m' ;;
      esac

      time_fmt=""
      if [[ -n "$timestamp" ]]; then
        time_fmt=" at $(date -r "$timestamp" '+%H:%M:%S' 2>/dev/null || date -d "@$timestamp" '+%H:%M:%S' 2>/dev/null)"
      fi

      results+=("$(printf '%s\t%s\n%s%s' "$target" "$session" "$state_fmt" "$time_fmt")")
    fi
  done < <(tmux list-panes -a -F "#{pane_tty}	#{session_name}:#{window_index}.#{pane_index}	#{session_name}")
  printf '%s\0' "${results[@]}"
}

[[ "${1:-}" == '--list' ]] && { emit_rows; exit 0; }

self="${BASH_SOURCE[0]}"
fzf_port=$((10000 + RANDOM % 50000))

(
  sleep 1
  while true; do
    sleep 3
    curl -s "localhost:$fzf_port" -d "reload($self --list)+track" >/dev/null 2>&1 || break
  done
) &
refresh_pid=$!
trap 'kill $refresh_pid 2>/dev/null; wait $refresh_pid 2>/dev/null' EXIT

export FZF_DEFAULT_OPTS=''
selected=$(emit_rows | fzf --ansi --read0 \
  --delimiter='\t' --with-nth=2 \
  --prompt="Select AI agent instance: " \
  --listen "$fzf_port" \
  --preview="tmux capture-pane -ept {1}" --preview-window='right,62%,wrap' \
  --bind="ctrl-x:reload($self --list)+track")

if [[ -n "$selected" ]]; then
  target=$(printf '%s' "$selected" | head -1 | cut -f1)

  if [[ -n "$TMUX" ]]; then
    tmux switch-client -t "$target"
  else
    tmux attach-session -t "$target"
  fi
fi
