#!/usr/bin/env zsh
setopt +o nomatch

oldAvailable=$(df -h / | tail -1 | awk '{print $4}')

if [ "$EUID" -eq 0  ]; then
  echo "Please run this command again without sudo!"
  exit 1
fi

sudo -v

echo "Empty the Trash on all mounted volumes and the main HDD..."
sudo rm -rfv /Volumes/*/.Trashes/* &>/dev/null
rm -rfv ~/.Trash/* &>/dev/null

echo "Cleaning System Log Files..."
sudo rm -rfv /Library/Logs/DiagnosticReports/* &>/dev/null
sudo rm -rfv /Library/Logs/Adobe/* &>/dev/null
rm -rfv ~/Library/Containers/com.apple.mail/Data/Library/Logs/Mail/* &>/dev/null
rm -rfv ~/Library/Logs/CoreSimulator/* &>/dev/null

echo "Cleaning Adobe Cache Files..."
rm -rfv ~/Library/Application\ Support/Adobe/Common/Media\ Cache\ Files/* &>/dev/null

echo "Cleaning iTunes iPhone/iPad updates..."
rm -rfv ~/Library/iTunes/iPhone\ Software\ Updates &>/dev/null
rm -rfv ~/Library/iTunes/iPad\ Software\ Updates &>/dev/null

echo "Cleaning Xcode simulator data..."
xcrun simctl delete unavailable

echo "Cleaning Xcode derived data..."
rm -rfv ~/Library/Developer/Xcode/DerivedData &>/dev/null

echo "Cleaning Xcode device support files..."
rm -rfv ~/Library/Developer/Xcode/iOS\ DeviceSupport/* &>/dev/null
rm -rfv ~/Library/Developer/Xcode/watchOS\ DeviceSupport/* &>/dev/null
rm -rfv ~/Library/Developer/Xcode/tvOS\ DeviceSupport/* &>/dev/null

echo "Cleaning Android Studio cache..."
rm -rfv ~/.android/build-cache &>/dev/null
rm -rfv ~/.android/cache &>/dev/null

echo "Cleaning Gradle..."
rm -rfv ~/.gradle/caches &>/dev/null
rm -rfv ~/.gradle/daemon &>/dev/null
rm -rfv ~/.gradle/wrapper &>/dev/null

echo "Cleaning Homebrew..."
brew cleanup -s &>/dev/null
brew autoremove &>/dev/null
sudo rm -rfv /Library/Caches/Homebrew/* &>/dev/null
brew tap --repair &>/dev/null

echo "Cleaning any old versions of gems..."
gem cleanup &>/dev/null

echo "Cleaning NPM cache..."
npm cache clean --force &>/dev/null

echo "Cleaning Yarn cache..."
yarn cache clean &>/dev/null

echo "Cleaning pnpm store..."
pnpm store prune &>/dev/null

echo "Cleaning pip cache..."
pip cache purge &>/dev/null
pip3 cache purge &>/dev/null

echo "Cleaning uv cache..."
uv cache clean &>/dev/null

echo "Cleaning Go caches..."
go clean -modcache &>/dev/null
go clean -cache &>/dev/null

echo "Cleaning system cache..."
rm -rfv ~/Library/Caches/* &>/dev/null
sudo rm -rfv /Library/Caches/* &>/dev/null

echo "Thinning Time Machine local snapshots..."
sudo tmutil thinlocalsnapshots / 999999999999 4 &>/dev/null

echo "Checking if Docker is running..."
docker info &>/dev/null

if [ $? -eq 0 ]; then
    docker system prune -a
    docker builder prune -f

    echo -n "Also prune Docker volumes? This DELETES named volumes and their data (databases, etc). [y/N] "
    read -r answer
    if [[ "$answer" == [yY]* ]]; then
        docker system prune -a --volumes
    fi
fi

echo "Searching for old node_modules that can be deleted..."
npx npkill --directory ~/dev

echo "Running periodic jobs..."
sudo periodic daily weekly monthly

# if [ ! -d /Applications/OmniDiskSweeper.app ]; then
#     echo "Installing OmniDiskSweeper..."
#     brew cask uninstall omnidisksweeper &> /dev/null
#     brew cask install omnidisksweeper
# fi

echo "Success!"

newAvailable=$(df -h / | tail -1 | awk '{print $4}')

echo "Previous space available: $oldAvailable"
echo "New space available: $newAvailable"
echo
echo Press any key to scan for big files...
read

gdu-go --no-cross --no-delete / || sudo ncdu -rx $(cut -f1 /usr/share/firmlinks | while read DIR; do /bin/echo -n "--exclude $DIR "; done) /

# open -a OmniDiskSweeper
